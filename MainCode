#we will ignore the cases in which phiB*delta -phi_R =0 or phi_B*delta-phi_R=0 since we are looking at the distribution of values for delta, so this is very unlikely to occur

#Aim: find the stationary distribution using the values calculated by Zac

#Inputs:
#N: population size
#phi_B,phi_R: directional selection values
#d: delta, denoting the diversifying selection value
#mu_rb, mu_br: mutation rates, where mu_rb denotes going from monomorphic red to polymorphic and mu_br denotes going from monomorphic blue to polymorphic

######################################################
#####################################################


stationary_distr2 <- function(N, phi_B,phi_R,d, mu_rb,mu_br){
  P <- numeric(2*N)

  if (phi_B* d != phi_R && phi_B != phi_R*d){

    P[(2*N)] <- mu_br * (phi_R)**(N-1) * ((phi_B * d)**N - (phi_R)**N) / ((phi_B * d) - phi_R)
    P[(N)] <- mu_rb * (phi_B)**(N-1) *   ((phi_R * d)**N - (phi_B)**N)/ ((phi_R * d) - phi_B)

    i<- 1:(N-1)#if most recent mutation is blue (indexing for vectorization)

    #splitting into sections to improve readability
    P[i] <- (mu_rb * mu_br * (N/i)) * #first part
      ((((N-i)*phi_R) + (i*phi_B*d))/(N-i)) * #second part
      (((phi_B * d)**(N-i) - (phi_R)**(N-i))/((phi_B*d)- phi_R)) * #third part
      (((phi_R)**(N-1) * (phi_B *d)**(i-1))) #fourth part


    index_red <- (N+1):(2*N-1)  #if most recent mutation is red
    m <- 2*N - index_red  #we are doing 2N-i since still counting the number of blue organisms, so it will decrease from here by 1 for every value of i


    P[index_red] <- (mu_rb * mu_br * (N/m)) * #first part
      ((((N-m)*phi_R*d) + (m*phi_B))/(N-m)) * #second part
      (((phi_R * d)**(m) - (phi_B)**(m))/((phi_R*d)- phi_B)) * #third part
      (((phi_B)**(N-1) * (phi_R *d)**(N-1-m))) #fourth part

  }

  else{ #if the boundary cases occur
    P[(2*N)] <- N*mu_br*phi_R**(2*N-2)
    P[(N)] <- N*mu_rb * phi_B**(2*N-2)
    i <- 1:N-1 #vectorized indexing
    #if most recent mutation is blue

    P[i] <- ((N-i) * mu_rb *mu_br *(N/i)) *
      (((N-i)*phi_R + i*phi_B*d)/(N-i)) *
      (phi_R**(2*N-i-2)) *
      ((phi_B*d)**(N-i-1))


    index_red <- (N+1):(2*N-1) #this refers to the s= (N-n, 1) #i.e if most recent mutation is red
    m <- 2*N - index_red #we are doing 2N-i since still counting the number of blue organisms, so it will decrease from here by 1 for every value of index_red

    P[index_red] <- (m * mu_rb * mu_br * (N/m)) *
      ((((N-m)*phi_R*d) +m*phi_B)/(N-m)) *
      (phi_B**(N+m-2)) *
      ((phi_R*d)**(N-m-1))

  }

  return(P/sum(P))}


