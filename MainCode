# generates a K-class discrete gamma model
# based on quantiles
discrete_gamma = function(alpha, beta, K){

#equally spaced probabilities 0, 1/K,...,1
  k = (0:K)/K

  #gamma quantiles for K equal- mass intervals
  q = qgamma(k, alpha, beta)

# mean of the gamma distribution inside each interval
  x = K*alpha*diff(pgamma(q,alpha+1,beta))/beta

  #returns the means of every interval
  return(x)
}



