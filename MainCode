#we first create a theoretical stationary distribution using the transition probabilities, this will be useful to confirm the stationary distribution
#worked out by Zac in thesis works as expected


#Inputs:
#N: population size
#phi_B: directional selection effect of blue mutation
#phi_R: directional selection effect of red mutation
#d: delta denoting the distribution of fitness effects
#mu_R, mu_B : mutation rates for red and blue mutations/alleles

theoretical_stat_distr <- function(N,phi_B,phi_R,d,mu_B,mu_R){
  P <- matrix(data=0,nrow=2*N,ncol=2*N)

  for (i in 1:(2*N)){
    if (i == N){ #if its monomorphic blue, then change with probability mu_R
      P[i,i] <- 1 - mu_R
      P[i,i+1] <- mu_R
    }
    else if (i == (2*N)){ #if its monomorphic red, then change with probability mu_B
      P[i,i] <- 1-mu_B
      P[i,1] <- mu_B

    }
    else if (i ==1){ #need to check what happens if N=1 or N=2 in this case and if this still works
      plus1 <- (((N-i)/N) * i * phi_B * d )/(i*phi_B *d + (N-i) * phi_R)
      neg1 <- (i * (N-i)/N * phi_R)/ (( i*phi_B * d ) + (N-i)* phi_R)
      P[i,i+1] <- plus1
      P[i,2*N] <- neg1
      P[i,i] <- (1-plus1-neg1)

    }

    #now that we've done the base cases can just do the rest of the cases
    else if (i >1 && i < N){
      plus1 <- (((N-i)/N) * i * phi_B * d )/(i*phi_B *d + (N-i) * phi_R)
      neg1 <- (i * (N-i)/N * phi_R)/ (( i*phi_B * d ) + (N-i) * phi_R)
      P[i,i-1] <- neg1
      P[i,i+1] <- plus1
      P[i,i] <- (1-neg1-plus1)
    }
    else if ( i > N && i < 2*N){
      m <- 2*N -i
      plus1 <- ((N-m)*m/N * phi_R * d )/((m*phi_R *d) + (N-m) * phi_B)
      neg1 <- (m* (N-m)/N * phi_B)/(m * phi_R * d + (N-m)*phi_B)
      P[i,i-1] <- neg1
      P[i,i+1] <- plus1
      P[i,i] <- (1-neg1-plus1)
    }

  }
  theoretical_distr <- P
  print(P)
  theoretical_eigen <-eigen(t(theoretical_distr)) #getting the eigenvalues
  theoretical_vectors <-Re(theoretical_eigen$vectors[,1])
  theoreticalresult <- theoretical_vectors/sum(theoretical_vectors)
  theoreticalresult
  return(theoreticalresult)}


