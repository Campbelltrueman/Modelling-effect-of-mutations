#Inputs:
#N: population size
#mu_rb,mu_br: mutation rates
#phi_B,phi_R: directional selection rates
#alpha,beta: parameters of gamma distribution
#S: number of simulations for our distribution of gamma values

#Output: vector of values

average_pi_dummy <- function(N, mu_rb, mu_br, phi_R, phi_B, alpha, beta, S){

  Total <- rep(0,times=(2*N))
  for (sim in 1:S){
    delta <- rgamma(1,shape=alpha,rate=beta)
    Total <- Total + stationary_distr2(N,phi_B=phi_B, phi_R=phi_R,d=delta,mu_rb=mu_rb,mu_br=mu_br)
  }
  return(Total/S)
}

