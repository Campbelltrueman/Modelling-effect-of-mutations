hypergeometric_sampling_discretised <- function(N,M,mu_rb,mu_br,phi_B,phi_R,alpha,beta,K){
  #getting the discretized stationary distribution

  pi_discretized <- average_pi_discretized(N=N,mu_rb=mu_rb,mu_br=mu_br,
                                           phi_R=phi_R,phi_B=phi_B,
                                           alpha=alpha,beta=beta,K=K)
  #psi_n step where we add the two values which are the same
  psi_values <- psi_n(pi_discretized)

  #now doing our hypergeometric sampling
  chi <- hypergeometric_prob(psi_values,N=N,M=M)

  return(chi)


}


