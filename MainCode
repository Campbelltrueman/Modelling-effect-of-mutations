# generates a K-class discrete gamma model
# based on quatiles
discrete_gamma = function(alpha, beta, K){

  # equally spaced probabilities 0, 1/K, ..., 1
  k = (0:K)/K

  # gamma quantiles for K equal-mass intervals
  q = qgamma(k, alpha, beta)

  # mean of the gamma distribution inside each interval
  x = K*alpha*diff(pgamma(q,alpha+1,beta))/beta

  # returns the means of every interval
  return(x)
}



#now getting the stationary distribution based on the discetization
average_pi_discretized <- function(N, mu_rb, mu_br, phi_R, phi_B,alpha,beta,K){
  dis_res <- discrete_gamma(alpha,beta,K)
  Total <- rep(0,times=(2*N))
  S <- length(dis_res)
  for (sim in 1:S){
    delta <- dis_res[sim]
    Total <- Total + stationary_distr2(N,phi_B=phi_B, phi_R=phi_R,d=delta,mu_rb=mu_rb,mu_br=mu_br)
  }
  return(Total/S)
}


