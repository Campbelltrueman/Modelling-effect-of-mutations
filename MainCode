ABC_simulation_discretized <- function(N, epsilon, I, mu_rb_true,mu_br_true,phi_R_true,phi_B_true,alpha_true,beta_true,K){
  #Approximate Bayesian Computation for our mutations simulator
  #INPUTS:
  #Epsilon: real number greater than zero which we use in ABC to define error value
  #I: number of iterations we want to do for ABC
  #true_values: values which have our true values of muR, muB, phiB, phiR, alpha, beta, should do all the same checks for these values
  #S: number of iterations for our average pi simulation

  #want to keep a matrix of all the values that doesn't have a set size
  matrix_results <- matrix(nrow=6)

  pi_true <- average_pi_discretized(N=N,mu_rb=mu_rb_true, mu_br=mu_br_true, phi_B=phi_B_true, phi_R=phi_R_true,alpha=alpha_true,beta=beta_true,K=K)

  for (i in 1:I){
    mu_rb_sim <- rexp(1,rate=1/(0.01/(2*N)))
    mu_br_sim <- rexp(1,rate=1/(0.01/(2*N)))
    #want to make sure these mu values are between 0 and 1

    beta_sim <- runif(1,1,40)
    alpha_sim <- 10
    #could make these alpha and beta equal to each other
    phi_B_sim <- 1
    phi_R_sim <-1
    pi_bar <- average_pi_discretized(N=N, mu_rb=mu_rb_sim, mu_br=mu_br_sim, phi_B=phi_B_sim,phi_R=phi_R_sim,alpha=alpha_sim,beta=beta_sim,K=K)
    e <- sum((pi_bar - pi_true)**2)
    if (any(is.na(pi_bar))) next #ignore if any of the values is NA
    if (e < epsilon){
      #results_list <- cbind(matrix_results,c(mu_R_sim,mu_B_sim,alpha_sim,beta_sim,phi_B_sim,phi_R_sim))
      matrix_results <- cbind(matrix_results,c(mu_rb_sim,mu_br_sim,alpha_sim,beta_sim,phi_B_sim,phi_R_sim))
    }

  }
  matrix_results <- as.data.frame(t(matrix_results[,-1])) #getting rid of the first NA column
  return(matrix_results)
}


