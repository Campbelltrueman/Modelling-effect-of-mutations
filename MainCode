geom_sampling_manual <- function(N,mu_rb,mu_br,phi_R,phi_B,alpha,beta,S,M){
  res1 <- average_pi_result(N=N, mu_rb=mu_rb, mu_br=mu_br, phi_R=phi_R, phi_B=phi_B, alpha=alpha, beta=beta, S=1000)

  #using this res1 we will get the psi values which adds the two stationary distributions
  psi_n <- numeric(N + 1)
  psi_n[1] <- res1[2*N]  #psi_0 #ie monomorphic red
  psi_n[N+1] <- res1[N] #psi_N #i.e. monomorphic blue
  for(i in 1:(N-1)){
    psi_n[i+1] <- res1[i] + res1[(2*N)-i] #this is equivalent to pi_(n,2) + pi_(N-n,1)
  }

  if( M >=N) {
    stop("sample must be smaller than population size")}
  chi <- numeric(M+1) #has size M+1 since taking chi0 to be a value
  for( i in 1:(M+1)){

    m <- i-1
    lower_n <- m #to keep same notation
    upper_n <- N-(M-m)

    if(lower_n <= upper_n){
      sum <- 0
      for (n in lower_n:upper_n){
        sum <- sum + ((choose(n,m) * choose(N-n,M-m)/choose(N,M)) * psi_n[n+1])
      }
      chi[i] <- sum
    }
    else{
      chi[i] <- 0
      }}
  return(chi)
}


