#Inputs:
#N: population size
#phi_B: directional selection size of blue mutation/allele
#phi_R: directional selection size of red mutation/allele
#d: representing delta, to denote the distribution of fitness effects value
#T: how many time steps/simulations to undertake
#init: initial value, i.e. initial value for the simulation where 1...N denotes if the most recent mutation was blue, with the integer value denoting how many blue organisms there are in the population
                      #and N+1,.....2N denotes if the most recent mutation was red, and the (integer value - N) denotes the number of red organisms there are in the population
#mu_R: denoting the red mutation rate
#mu_B: denoting the blue mutation rate.


#Outputs: A base R graph showing state space simulation, with colour showing the most recent mutation, and the value of n denoting the number of organisms of that mutation
set.seed(123) #for replicability
statespacesim <- function(N,phi_B, phi_R,d,T,init,mu_R,mu_B){


  ############################################################################
  #first doing our checks for our parameters of interest
  if( N <= 0 || N != as.integer(N)){
    return(print("Population size is negative or zero"))
  }
  if (phi_B < 0 || phi_R <0){
    return(print("both  Phi value should be non negative"))
  }
  if (mu_R < 0 || mu_R >1){
    return(print("mu_R should be between 0 and 1"))
  }
  if (mu_B < 0 || mu_B >1){
    return(print("mu_B should be between 0 and 1"))
  }
  if (T <0 || T != as.integer(T)){
    return(print("T should be a positive integer"))
  }
  if(init <1 || init != as.integer(init) || init >(2*N) ){
    return(print("your initial value should be a positive integer"))
  }
  ############################################################################

  #Now we are going to do the state space main calculation:
  #we are 'for now' going to call each of the state space locations as 1 to 6
  #S <- vector(mode="list",length = T)

  S <- seq(1,T)
  colour_value <- character(length=T)

  Newmatrix <- matrix(data=0,nrow=T,ncol=2*N,byrow=TRUE) #creating a matrix of general size
  Newmatrix[1,init] <- 1
  S[1] <- init #putting our initial condition in
  for (i in 2:T){
    n <- S[i-1]
    if (n < N){ # if the last value was blue e.g. (1,B) or (2,B)
      # I think I potentially have to not include e.g. (1,B) within it.
    }
    if(n == 1){ # (1,B)

      plus1 <- (((N-n)/N) * n * phi_B * d )/(n*phi_B *d + (N-n) * phi_R)
      neg1 <- (n * (N-n)/N * phi_R)/ (( n*phi_B * d ) + (N-n)* phi_R)
      S[i] <- sample(c(2*N,n+1,n),size=1,prob=c(neg1,plus1,(1-neg1-plus1)))
      Newmatrix[i,S[i]] <- 1
    }

    if (n < N & n>1){ #(n,B)

      plus1 <- (((N-n)/N) * n * phi_B * d )/(n*phi_B *d + (N-n) * phi_R)
      neg1 <- (n * (N-n)/N * phi_R)/ (( n*phi_B * d ) + (N-n) * phi_R)
      S[i] <- sample(c(n-1,n+1,n),size=1,prob=c(neg1,plus1,(1-neg1-plus1)))
      Newmatrix[i,S[i]] <- 1
    }
    if(n == N){ #(B)
      S[i] <- sample(c(N,N+1),size=1, prob=c(1-mu_R,mu_R))
      Newmatrix[i,S[i]] <- 1
    }
    if (n > N & n < 2*N){ #(n,R)
      m <- n %% N #getting the modulus value
      plus1 <- ((N-m)*m/N * phi_R * d )/((m*phi_R *d) + (N-m) * phi_B)
      neg1 <- (m* (N-m)/N * phi_B)/(m * phi_R * d + (N-m)*phi_B)
      S[i] <- sample(c(n-1,n+1,n),size=1,prob=c(neg1,plus1,(1-neg1-plus1)))
      Newmatrix[i,S[i]] <- 1

    }

    if (n == (2*N)){ #(R)
      S[i] <- sample(c(2*N,1),size=1, prob=c(1-mu_B,mu_B))  #here I am going to sample with probability mu that the mutation works effectively
      #value is 1 with prob 1-mu
      #value is 2 with prob mu
      Newmatrix[i,S[i]] <- 1

    }}
  n_list <- numeric(T)

  for (i in 1:T){ #just doing this at the end rather than repeating code lots of times, can probably vectorize this eventually
    n_values <- S[i] %% N #getting modulus value
    n_values <- ifelse(n_values == 0, N, n_values) #if the modulus value is 0 replace this with N
    n_list[i] <- n_values
    colour_value[i] <- ifelse(S[i] <= N, "blue","red")

  }
  blue_values <- n_list
  red_values <- n_list
  blue_values[colour_value != "blue"] <- NA
  red_values[colour_value != "red"] <- NA

  plot(1:T, n_list, type="n", xlab="simulation number", ylab="number with coloured allele", ylim=c(1, N),main="state space simulation")
  lines(1:T, blue_values,type="s",xlab="simulation number",ylab="n",col="blue")
  lines(1:T, red_values,type="s",col="red")


  return(list(S=S,Newmatrix=Newmatrix))

}


