average_pi_discretized <- function(N, mu_rb, mu_br, phi_R, phi_B,alpha,beta,K){
  dis_res <- discrete_gamma(alpha,beta,K)
  Total <- rep(0,times=(2*N))
  S <- length(dis_res)
  for (sim in 1:S){
    delta <- dis_res[sim]
    Total <- Total + stationary_distr2(N,phi_B=phi_B, phi_R=phi_R,d=delta,mu_rb=mu_rb,mu_br=mu_br)
  }
  return(Total/S)
}

