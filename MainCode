psi_n <- function(average_pi_result){
  N <- length(average_pi_result)/2
  psi <- numeric(N + 1)
  psi[1] <- average_pi_result[2*N]  #psi_0 #ie monomorphic red
  psi[N+1] <- average_pi_result[N] #psi_N #i.e. monomorphic blue
  for(i in 1:(N-1)){
    psi[i+1] <- average_pi_result[i] + average_pi_result[(2*N)-i] #this is equivalent to pi_(n,2) + pi_(N-n,1)
  }
  return(psi)
}
